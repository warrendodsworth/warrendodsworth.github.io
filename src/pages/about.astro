---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About | Warren Dodsworth" path="/about/">
  <section class="page-hero">
    <div class="shell">
      <div class="panel">
        <span class="kicker">About</span>
        <h1>Experience, product thinking, and a practical builder mindset.</h1>
        <p class="lead">
          This page will become the structured replacement for the old resume-style profile, with a
          clearer story, stronger hierarchy, and better separation between biography, skills, and
          work.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
