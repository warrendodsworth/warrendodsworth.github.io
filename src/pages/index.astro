---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const allProjects = (await getCollection("projects")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const allPosts = await getCollection("blog");
const featuredProjects = allProjects.filter((project) => project.data.featured);
const latestPost = allPosts[0];
const pillars = [
  "Product strategy and technical delivery kept in the same conversation",
  "Hands-on experience across web platforms, mobile products, cloud systems, and growth tooling",
  "A practical bias toward clarity, momentum, and work that survives contact with reality",
];
---

<BaseLayout
  title="Warren Dodsworth"
  description="Warren Dodsworth helps turn product ideas into workable systems through product strategy, delivery leadership, and hands-on technical execution."
  path="/"
  ogImage="/og-social-preview.png"
>
  <section class="hero">
    <div class="shell hero-grid">
      <div class="panel hero-copy hero-copy--wide">
        <div class="eyebrow">Product strategy, delivery leadership, and digital execution</div>
        <h1>Turning ambitious ideas into products teams can actually ship and grow.</h1>
        <p>
          Warren Dodsworth works where commercial goals, product decisions, and technical
          delivery need to stay connected. The focus is not just on building software, but on
          shaping clearer products, stronger systems, and execution that keeps moving.
        </p>
        <div class="hero-actions">
          <a class="button" href="/projects/">View selected work</a>
          <a class="button-muted" href="/about/">Read the profile</a>
        </div>
        <ul class="hero-points">
          {pillars.map((pillar) => (
            <li>{pillar}</li>
          ))}
        </ul>
      </div>
      <div class="hero-stack">
        <div class="panel hero-note">
          <span class="kicker">Current focus</span>
          <h2>People platforms, decision-support products, and delivery that holds together.</h2>
          <p>
            Current work spans products like PeopleX and Insight 91, with a focus on creating
            useful systems, stronger product narratives, and delivery that does not get lost in
            complexity.
          </p>
        </div>
        <div class="panel hero-image">
          <img
            src="/warren-professional.png"
            alt="Professional portrait of Warren Dodsworth"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section-head">
        <div>
          <span class="kicker">What this site covers</span>
          <h2>Selected work, decision-making context, and the thinking behind the build.</h2>
        </div>
        <p>
          This is where product work, technical execution, and broader perspective come together in
          a format that is clearer, more useful, and closer to how the work actually happens.
        </p>
      </div>
      <div class="feature-band">
        <article class="panel feature-card feature-card--accent">
          <span class="kicker">About</span>
          <h3>A builder who can move between business context and implementation detail.</h3>
          <p>
            The profile focuses on how Warren works: clarifying direction, improving systems, and
            keeping strategy, architecture, and delivery aligned.
          </p>
          <a class="button-muted" href="/about/">Explore profile</a>
        </article>
        <article class="panel feature-card">
          <span class="kicker">Projects</span>
          <h3>Product stories with real scope, systems, and outcomes.</h3>
          <p>
            Projects like PeopleX, Insight 91, and other product builds show how strategy,
            architecture, and delivery come together in practice.
          </p>
          <a class="button-muted" href="/projects/">Browse projects</a>
        </article>
        <article class="panel feature-card feature-card--image">
          <img src="/bg-shrine.jpg" alt="Melbourne skyline with clouds and open space" />
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section-head">
        <div>
          <span class="kicker">Featured work</span>
          <h2>Products shaped around clarity, usability, and better decisions.</h2>
        </div>
        <p>
          The strongest through-line in the work is making complex domains easier to understand,
          navigate, and act on.
        </p>
      </div>
      <div class="grid">
        {featuredProjects.map((project) => (
          <article class="panel card">
            <span class="meta-label">{project.data.client}</span>
            <h3>
              <a href={`/projects/${project.id}/`}>{project.data.title}</a>
            </h3>
            <p>{project.data.summary}</p>
            <div class="tag-row">
              {project.data.techStack.map((item) => (
                <span>{item}</span>
              ))}
            </div>
          </article>
        ))}
        {latestPost && (
          <article class="panel card card--contrast">
            <span class="meta-label">Writing</span>
            <h3>
              <a href={`/writing/${latestPost.id}/`}>{latestPost.data.title}</a>
            </h3>
            <p>{latestPost.data.summary}</p>
            <a class="button-muted" href="/writing/">Read more thinking</a>
          </article>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
