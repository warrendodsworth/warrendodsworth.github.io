---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = await getCollection("projects");
---

<BaseLayout title="Projects | Warren Dodsworth" path="/projects/">
  <section class="page-hero">
    <div class="shell stack">
      <div class="panel page-copy">
        <span class="kicker">Projects</span>
        <h1>Case studies, product work, and selected builds.</h1>
        <p>
          Structured project entries now live in an Astro content collection, giving the site a
          clean path toward richer case studies and future showcase pages.
        </p>
      </div>
      <div class="grid">
        {projects.map((project) => (
          <article class="panel card">
            <h3>
              <a href={`/projects/${project.id}/`}>{project.data.title}</a>
            </h3>
            <p>{project.data.summary}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
