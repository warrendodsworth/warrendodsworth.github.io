---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Projects | Warren Dodsworth" path="/projects/">
  <section class="page-hero">
    <div class="shell stack">
      <div class="panel page-copy">
        <span class="kicker">Projects</span>
        <h1>Case studies, product work, and selected builds.</h1>
        <p>
          This section will hold structured project entries and richer case studies once the Astro
          content model is in place.
        </p>
      </div>
      <div class="grid">
        <article class="panel card">
          <h3>Wiseguy Investor</h3>
          <p>A future case study placeholder for the investing-focused personal project.</p>
        </article>
        <article class="panel card">
          <h3>Inspire Me</h3>
          <p>A future case study placeholder for the Men of Melbourne book campaign work.</p>
        </article>
        <article class="panel card">
          <h3>More selected work</h3>
          <p>Additional projects will be added here as the old profile content is migrated.</p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
