---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = await getCollection("projects");
---

<BaseLayout
  title="Projects | Warren Dodsworth"
  description="Selected projects and case studies from Warren Dodsworth."
  path="/projects/"
  ogImage="/bg-city2.jpg"
>
  <section class="page-hero">
    <div class="shell stack">
      <div class="panel page-copy">
        <span class="kicker">Projects</span>
        <h1>Case studies, product work, and selected builds.</h1>
        <p>
          Structured project entries now live in an Astro content collection, giving the site a
          clean path toward richer case studies and future showcase pages.
        </p>
      </div>
      <div class="grid project-grid">
        {projects.map((project) => (
          <article class={`panel card ${project.data.featured ? "card--feature" : ""}`}>
            <span class="meta-label">{project.data.status}</span>
            <h3>
              <a href={`/projects/${project.id}/`}>{project.data.title}</a>
            </h3>
            <p>{project.data.summary}</p>
            <div class="tag-row">
              {project.data.techStack.map((item) => (
                <span>{item}</span>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
