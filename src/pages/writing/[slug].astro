---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const path = `/writing/${entry.id}/`;
---

<BaseLayout
  title={`${entry.data.title} | Writing | Warren Dodsworth`}
  description={entry.data.description}
  path={path}
  ogImage="/og-social-preview.png"
  ogType="article"
>
  <section class="page-hero">
    <div class="shell page-grid page-grid--writing">
      <div class="panel page-copy">
        <span class="kicker">Writing</span>
        <h1>{entry.data.title}</h1>
        <p class="lead">{entry.data.summary}</p>
        <div class="tag-row">
          {entry.data.tags.map((tag) => (
            <span>{tag}</span>
          ))}
        </div>
        <div class="collection-copy prose-space">
          <Content />
        </div>
      </div>
      <aside class="panel page-aside page-aside--text">
        <div class="page-aside__body">
          <span class="kicker">Writing focus</span>
          <h2>Thinking that stays close to execution.</h2>
          <p>
            These notes are meant to be practical: product strategy, delivery judgment, systems
            thinking, and the decisions that shape useful work over time.
          </p>
          <p class="meta-block">{entry.data.pubDate.toLocaleDateString("en-AU")}</p>
          <div class="card-actions">
            <a class="button-muted" href="/rss.xml">Follow via RSS</a>
          </div>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
